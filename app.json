{
  "expo": {
    "name": "InovaCalc",
    "slug": "calculadoraInovassie",
    "version": "1.0.0",
    "scheme": "inovassie",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8e15b68f-2f4c-49b6-a98d-b29db3cb2408",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#042C53"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inovassie.calculadora"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#042C53"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.inovassie.calculadora"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "O InovaCalc precisa acessar sua galeria para atualizar sua foto de perfil.",
          "cameraPermission": "O InovaCalc precisa da câmera para tirar sua foto de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#042C53",
          "sounds": []
        }
      ],
      "expo-updates"
    ],
    "extra": {
      "eas": {
        "projectId": "8e15b68f-2f4c-49b6-a98d-b29db3cb2408"
      }
    },
    "owner": "albertogabriel"
  }
}
